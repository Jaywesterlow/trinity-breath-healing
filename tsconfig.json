{
	"extends": "./.svelte-kit/tsconfig.json",
	"compilerOptions": {
		"strict": true,
		"noUncheckedIndexedAccess": true,
		"verbatimModuleSyntax": true,
		"isolatedModules": true,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"skipLibCheck": true,
		"moduleResolution": "bundler"
		// All path aliases ($lib, $schema, $content, $app) auto-generated in .svelte-kit/tsconfig.json via kit.alias
	},
	"exclude": [
		// Fixture files are intentionally invalid TypeScript (missing required props).
		// They are compiled individually by tsc --ignoreconfig in image.test.ts (Tests 5-7).
		// Including them here would cause svelte-check to report errors for intentionally bad code.
		"tests/fixtures/**/*"
	]
}
